---
import Base from "@/layouts/Base.astro";
import config from "@/config/config.json";
const { site } = config;

const boothBannerUrl = "https://asset.booth.pm/static-images/banner/200x40_01.png";

const books = [
  {
    id: "essen-spiel-2023",
    title: "Essen SPIEL Guidebook 2023",
    image: "/images/books/Essen_Spiel_Guidebook_2023.jpg",
    alt: "Essen SPIEL ガイドブック",
    boothUrl: "https://imkarton.booth.pm/items/4767409",
    description:
      "世界最大のボードゲームイベント「SPIEL Essen」への参加を検討している方に向けた、一般参加者目線の実践ガイドブック。イベントの基礎知識からドイツへの渡航方法、予算の節約術まで幅広くカバーしています。",
    features: [
      "多数の新作から優良作を見つけるメソッド",
      "ボードゲームの持ち帰り・発送に関する節約術",
      "エッセン前後のドイツ観光情報",
    ],
  },
  {
    id: "gen-con",
    title: "Gen Con Guidebook",
    image: "/images/books/GenCon_Guidebook.jpg",
    alt: "Gen Con ガイドブック",
    boothUrl: "https://imkarton.booth.pm/items/6283498",
    description:
      "北米最大のアナログゲームイベント「Gen Con」の旅行ガイドブック。シリーズ第2弾として、アメリカならではのイベント事情を128ページのフルカラーで紹介しています。",
    features: [
      "アメリカのイベント事情（ホテルやスタジアムも会場に）",
      "旅行計画の立て方と持参アイテムリスト",
      "ボードゲームの効率的な運び方と参加型イベント紹介",
    ],
  },
  {
    id: "essen-spiel-2023-plus-one",
    title: "Essen SPIEL Guidebook 2023 Plus One",
    image: "/images/books/Essen_Spiel_Guidebook%202023_Plus_One.jpg",
    alt: "Essen SPIEL Guidebook 2023 Plus One",
    boothUrl: "https://imkarton.booth.pm/items/7955335",
    description:
      "リニューアルされた「SPIEL Essen」の最新情報を48ページのフルカラーで追補した別冊。前作と合わせて読むことで、新しくなったエッセンの姿をより詳しく知ることができます。",
    features: [
      "見やすくなったSPIEL Essenの新レイアウト情報",
      "旅行時のお得情報やトラブル対応のポイント",
      "ドイツ鉄道運休トラブルの体験記",
    ],
  },
  {
    id: "fij-cannes",
    title: "FIJ Cannes Guidebook",
    image: "/images/books/FIJ_Cannes_Guidebook.png",
    alt: "FIJ カンヌ ガイドブック",
    boothUrl: "https://imkarton.booth.pm/items/7721176",
    description:
      "フランス最大・世界第3位のアナログゲームイベント「Festival International des Jeux」のガイドブック。シリーズ第3弾にして過去最大の138ページ。イベント紹介から旅行テクニック、カンヌの観光情報まで網羅しています。",
    features: [
      "FIJ（Festival International des Jeux）のイベント紹介",
      "フランス旅行のテクニックと実践情報",
      "カンヌの観光地情報と現地ガイダンス",
    ],
  },
];
---

<Base title={`海外アナログゲームイベント旅行ガイドブック | ${site.title}`}>
  <section class="section">
    <div class="container max-w-4xl space-y-8">
      <p class="text-sm uppercase tracking-[0.3em] text-primary/80">Books</p>
      <h1 class="text-3xl md:text-4xl font-semibold">海外アナログゲームイベント旅行ガイドブック</h1>
      <p class="text-lg text-text-light dark:text-darkmode-text-light leading-relaxed">
        海外のアナログゲームイベントを訪れる人に向けたガイドブックシリーズを制作・刊行しています。現地取材で得た最新情報と、ブース巡りや周辺観光を楽しむための実践的なノウハウを凝縮しました。
      </p>

      <div class="space-y-6">
        {books.map((book) => (
          <article id={book.id} class="flex flex-col sm:flex-row rounded-3xl border border-border/60 dark:border-border/30 bg-white dark:bg-darkmode-body shadow-sm overflow-hidden">
            <div class="sm:w-48 md:w-56 shrink-0 bg-light dark:bg-darkmode-light/60 flex items-center justify-center p-4">
              <img
                src={book.image}
                alt={book.alt}
                class="max-h-72 w-auto object-contain rounded-lg shadow-md"
                loading="lazy"
              />
            </div>
            <div class="flex flex-col flex-1 p-6 space-y-3">
              <h2 class="text-xl md:text-2xl font-semibold text-primary">{book.title}</h2>
              <p class="text-sm text-text-light dark:text-darkmode-text-light leading-relaxed">
                {book.description}
              </p>
              <ul class="list-disc pl-5 text-sm text-text-light dark:text-darkmode-text-light space-y-1">
                {book.features.map((feature) => (
                  <li>{feature}</li>
                ))}
              </ul>
              <div class="pt-2 mt-auto">
                <a href={book.boothUrl} target="_blank" rel="noopener noreferrer">
                  <img
                    src={boothBannerUrl}
                    alt="BOOTHで購入"
                    width="200"
                    height="40"
                    loading="lazy"
                  />
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>
</Base>
